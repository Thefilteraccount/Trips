                nearby: "Dunnellon, FL",
                vibe: "Swimming / nature",
                features: "Rainbow Springs, Dunnellon, FL 34432"
            },
            {
                name: "Wekiwa Springs State Park",
                coords: [28.7129, -81.4630],
                price: "State park",
                nearby: "Apopka / Orlando area",
                vibe: "Springs / swimming",
                features: "1800 Wekiwa Cir, Apopka, FL 32712"
            },
            {
                name: "Tammy's Teriyaki House",
                coords: [28.5522, -81.4554],
                price: "Food stop",
                nearby: "Orlando, FL",
                vibe: "Casual teriyaki",
                features: "5600 W Colonial Dr, Orlando, FL 32808"
            }
        ];

        hotels.forEach(hotel => {
            const marker = L.marker(hotel.coords).addTo(map);

            const label = L.divIcon({
                className: 'label-marker',
                html: hotel.name
            });
            L.marker(hotel.coords, { icon: label }).addTo(map);

            const tooltip = `
                💲 <b>Type:</b> ${hotel.price}<br/>
                📍 <b>Nearby:</b> ${hotel.nearby}<br/>
                🌟 <b>Vibe:</b> ${hotel.vibe}<br/>
                🛎️ <b>Address:</b> ${hotel.features}
            `;
            marker.bindTooltip(tooltip);
        });
    </script>
</body>
</html>
