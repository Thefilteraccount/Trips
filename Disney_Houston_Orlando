<!DOCTYPE html>
<html>
<head>
    <title>Houston to Orlando Road Trip Map</title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <style>
        #map { height: 100vh; width: 100%; }

        .label-marker {
            font-size: 14px;
            font-weight: bold;
            color: black;
            background: none !important;
            border: none !important;
            padding: 0;
            box-shadow: none;
        }
    </style>
</head>
<body>
    <h3 style="text-align:center;">Houston to Orlando Road Trip Stops</h3>
    <div id="map"></div>

    <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
    <script>
        var map = L.map('map').setView([30.2, -88.6], 6);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 18,
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);

        const hotels = [
            {
                name: "Daniel's Bar-B-Que & Meat Market",
                coords: [29.8040, -94.9579],
                price: "Food stop",
                nearby: "Baytown, TX / I-10",
                vibe: "Texas barbecue",
                features: "6010 Thompson Rd, Baytown, TX 77521"
            },
            {
                name: "The Boudain Hut",
                coords: [29.8845, -93.9401],
                price: "Food stop",
                nearby: "Port Arthur, TX",
                vibe: "Boudin and Cajun food",
                features: "5714 Gulfway Dr, Port Arthur, TX 77642"
            },
            {
                name: "Millennium Park",
                coords: [30.2271, -93.2224],
                price: "Park stop",
                nearby: "Lake Charles, LA",
                vibe: "Family park / waterfront",
                features: "900 Lakeshore Dr, Lake Charles, LA 70601"
            },
            {
                name: "In-Laws",
                coords: [30.2366, -93.0135],
                price: "Food stop",
                nearby: "Iowa, LA",
                vibe: "Cajun food",
                features: "1121 Lowe-Grout Rd, Iowa, LA 70647"
            },
            {
                name: "Oil and Gas Park",
                coords: [30.2216, -92.6571],
                price: "Park stop",
                nearby: "Jennings, LA / I-10",
                vibe: "Quick scenic stop",
                features: "100 Rue de l'Acadie, Jennings, LA 70546"
            },
            {
                name: "Billy's Boudin & Cracklins",
                coords: [30.2357, -92.1060],
                price: "Food stop",
                nearby: "Scott, LA / Lafayette area",
                vibe: "Boudin and cracklins",
                features: "1815 St Mary St, Scott, LA 70583"
            },
            {
                name: "Hebert's Boudin & Cracklins",
                coords: [30.3086, -91.8734],
                price: "Food stop",
                nearby: "Breaux Bridge, LA",
                vibe: "Cajun boudin stop",
                features: "2926 Grand Point Hwy, Breaux Bridge, LA 70517"
            },
            {
                name: "Tony's Seafood",
                coords: [30.4945, -91.1488],
                price: "Food stop",
                nearby: "Baton Rouge, LA",
                vibe: "Seafood market and restaurant",
                features: "5215 Plank Rd, Baton Rouge, LA 70805"
            },
            {
                name: "Louisiana State Capitol",
                coords: [30.4573, -91.1875],
                price: "Sightseeing",
                nearby: "Downtown Baton Rouge",
                vibe: "Historic / government landmark",
                features: "900 N 3rd St, Baton Rouge, LA 70802"
            },
            {
                name: "Parrain's Seafood Restaurant",
                coords: [30.4247, -91.1393],
                price: "Food stop",
                nearby: "Baton Rouge, LA",
                vibe: "Seafood restaurant",
                features: "3225 Perkins Rd, Baton Rouge, LA 70808"
            },
            {
                name: "Bud & Alley's Waterfront Restaurant & Bar",
                coords: [30.3209, -86.1396],
                price: "Food stop",
                nearby: "Santa Rosa Beach / 30A",
                vibe: "Beachfront dining",
                features: "2236 E County Rd 30A, Santa Rosa Beach, FL 32459"
            },
            {
                name: "The Big Chill 30A",
