                features: "15700 L C Hilton Jr Dr, Panama City Beach, FL 32413"
            },
            {
                name: "Manatee Springs State Park",
                coords: [29.4904, -82.9765],
                price: "State park",
                nearby: "Chiefland, FL",
                vibe: "Springs / nature",
                features: "11650 NW 115th St, Chiefland, FL 32626"
            },
            {
                name: "Silver Springs State Park",
                coords: [29.2169, -82.0563],
                price: "State park",
                nearby: "Silver Springs / Ocala area",
                vibe: "Clear water springs",
                features: "5656 E Silver Springs Blvd, Silver Springs, FL 34488"
            },
            {
                name: "Rainbow Springs",
